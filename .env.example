# ==============================================================================
# Environment variables for the news-sentiment trading bot.
#
# Copy the ones you need into your platform's dashboard (Railway: Project ->
# Variables) or, for local dev, into a `.env` file / your shell profile /
# config.ini. Environment variables always take precedence over config.ini.
#
# MANDATORY: only the two Alpaca keys. Everything else has a sensible default
# matching "simplified mode" (static universe, Alpaca's free news feed,
# offline lexicon sentiment) — see README.md.
# ==============================================================================

# ---- Operating mode: PAPER / DRY_RUN / LIVE --------------------------------
# This is the ONLY thing you change to go from paper to live trading — no code
# changes are ever required. See README.md "Operating modes" for the full
# explanation. Three independent switches must all agree before a single real
# order is ever submitted:
#   1. TRADING_MODE=live               (which account + code path)
#   2. LIVE_TRADING_CONFIRMED=true     (explicit "I mean it" confirmation)
#   3. RISK_DRY_RUN=false              (the existing risk-layer dry-run gate)
#
#   TRADING_MODE=paper     (default) - Alpaca PAPER account, paper trades.
#                            Uses ALPACA_API_KEY / ALPACA_SECRET_KEY below.
#   TRADING_MODE=dry_run    - connects to your LIVE Alpaca account (real
#                            balances/positions) but NEVER submits an order -
#                            logs + Telegram-notifies what it would have done.
#                            Requires ALPACA_LIVE_API_KEY / ALPACA_LIVE_SECRET_KEY.
#                            The safe way to rehearse against the live account.
#   TRADING_MODE=live       - connects to your LIVE account and places real
#                            orders. Also requires LIVE_TRADING_CONFIRMED=true
#                            and RISK_DRY_RUN=false. Missing any one of the
#                            three keeps the bot in a safe, order-free state.
TRADING_MODE=paper
LIVE_TRADING_CONFIRMED=false

# ---- Alpaca PAPER account (REQUIRED — used when TRADING_MODE=paper) -------
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# ---- Alpaca LIVE account (required only for TRADING_MODE=dry_run or live) -
# Deliberately separate variables from the paper keys above, so switching
# modes can never accidentally point at the wrong account. Get these from
# Alpaca's live (non-paper) account dashboard.
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_SECRET_KEY=

# ---- Universe ---------------------------------------------------------------
UNIVERSE_PROVIDER=static   # static (no key) | mention (needs FINNHUB_API_KEY)
UNIVERSE_TOP_N=50
UNIVERSE_MIN_SYMBOLS=25

# ---- News ---------------------------------------------------------------
NEWS_PROVIDER=alpaca       # alpaca (no key) | finnhub | newsapi
NEWSAPI_API_KEY=
FINNHUB_API_KEY=
NEWS_LOOKBACK_HOURS=12
NEWS_MAX_ARTICLES_PER_SYMBOL=15

# ---- Sentiment ---------------------------------------------------------------
SENTIMENT_PROVIDER=lexicon # lexicon (no key) | claude | openai
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
SENTIMENT_TEMPERATURE=0.0

# ---- Strategy: buy / sell rules -------------------------------------------
STRATEGY_BUY_THRESHOLD=8.0
STRATEGY_SELL_THRESHOLD=-5.0
STRATEGY_MIN_HEADLINES=5
STRATEGY_SELL_MIN_HEADLINES=3
STRATEGY_MAX_INTRADAY_RUNUP_PCT=8.0

# --- Confirmation filters (new) ---
STRATEGY_REQUIRE_PRICE_ABOVE_SMA=true
STRATEGY_SMA_PERIOD=20
STRATEGY_MIN_VOLUME_RATIO=1.5
STRATEGY_VOLUME_LOOKBACK_DAYS=20

# --- Market filters ---
STRATEGY_MARKET_FILTER_SYMBOL=SPY
STRATEGY_MARKET_FILTER_MAX_DROP_PCT=2.0        # pause buys if SPY down > X% today (0 disables)
STRATEGY_MARKET_REGIME_FILTER_ENABLED=true     # pause buys if SPY below its own SMA
STRATEGY_MARKET_REGIME_MA_PERIOD=50            # ...the 50-day SMA, specifically

# ---- Risk ---------------------------------------------------------------
RISK_DRY_RUN=true                # start here; flip to false only after watching it run.
                                  # This is also the FINAL gate for TRADING_MODE=live —
                                  # real orders require TRADING_MODE=live AND
                                  # LIVE_TRADING_CONFIRMED=true AND RISK_DRY_RUN=false,
                                  # all three, together.
RISK_MAX_POSITION_PCT=5.0
RISK_MAX_OPEN_POSITIONS=10
RISK_MAX_TOTAL_EXPOSURE_PCT=50.0
RISK_MAX_NEW_POSITIONS_PER_CYCLE=3
RISK_MAX_POSITIONS_PER_SECTOR=3
RISK_REENTRY_COOLDOWN_HOURS=24
RISK_STOP_LOSS_PCT=10.0
RISK_TAKE_PROFIT_PCT=20.0
RISK_MAX_ORDER_NOTIONAL=0        # 0 = disabled
RISK_DAILY_LOSS_LIMIT_PCT=4.0

# ---- Schedule ---------------------------------------------------------------
SCHEDULE_RUN_MINUTES=0,30
SCHEDULE_MARKET_TIMEZONE=America/New_York

# ---- Logging & data persistence --------------------------------------------
# IMPORTANT on Railway: the filesystem is EPHEMERAL unless you attach a
# Volume. Without one, state.json / trades.csv / closed_trades.csv reset on
# every redeploy — cooldowns and the performance report's trade history
# disappear. Attach a Volume (Railway dashboard -> your service -> Volumes)
# and point these paths at its mount, e.g. /data/...  See DEPLOYMENT.md.
TRADE_LOG_PATH=logs/trades.csv
CLOSED_TRADES_PATH=logs/closed_trades.csv
DAILY_SUMMARY_PATH=logs/daily_summary.log
REPORT_DIR=logs/reports
RUN_LOG_PATH=logs/bot.log
STATE_PATH=logs/state.json

LOG_LEVEL=INFO
LOG_FORMAT=text            # text (human-readable) | json (structured, recommended on Railway)

# ---- Retry policy (applies to every external API call) ---------------------
RETRY_MAX_ATTEMPTS=4
RETRY_BASE_DELAY_SECONDS=1.0

# ---- Telegram notifications (optional but recommended) ---------------------
# See NOTIFICATIONS.md for step-by-step BotFather / chat-id instructions.
# Auto-enabled once both are set; TELEGRAM_ENABLED=false force-disables even
# if credentials are present.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# TELEGRAM_ENABLED=true

# ---- Dashboard integration: Monthly Research Report (optional) -------------
# Only needed if you want the bot to automatically trigger the dashboard's
# Monthly Research Report once a month and relay its summary to Telegram (via
# the existing notification pipeline - respects the monthly_research_report
# row in Notification Settings, same as every other notification type).
# Leave both blank and the monthly job silently no-ops - the dashboard's own
# "Generate Report Now" button on /monthly-report still works standalone.
# DASHBOARD_INTERNAL_URL is this project's dashboard service's own base URL
# (e.g. the Railway-provided domain for the Next.js service, not the bot's).
# DASHBOARD_INTERNAL_API_KEY must match DASHBOARD_INTERNAL_API_KEY set on the
# dashboard service itself (see dashboard's own env vars in README.md) - it's
# a shared secret, not a real user credential, since the bot has no browser
# session to log in with.
DASHBOARD_INTERNAL_URL=
DASHBOARD_INTERNAL_API_KEY=

# ---- Railway "Web Service" compatibility (optional) ------------------------
# If you deploy this as a Railway Worker (recommended), PORT is unset and
# this is irrelevant. If you deploy as a Web Service, Railway sets PORT for
# you automatically — you don't need to set it yourself.
# PORT=8080
