# ==============================================================================
# Environment variables for the news-sentiment trading bot.
#
# Copy the ones you need into your platform's dashboard (Railway: Project ->
# Variables) or, for local dev, into a `.env` file / your shell profile /
# config.ini. Environment variables always take precedence over config.ini.
#
# MANDATORY: only the two Alpaca keys. Everything else has a sensible default
# matching "simplified mode" (static universe, Alpaca's free news feed,
# offline lexicon sentiment) — see README.md.
# ==============================================================================

# ---- Alpaca (REQUIRED) -----------------------------------------------------
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true          # leave true; the bot refuses to start otherwise

# ---- Universe ---------------------------------------------------------------
UNIVERSE_PROVIDER=static   # static (no key) | mention (needs FINNHUB_API_KEY)
UNIVERSE_TOP_N=50
UNIVERSE_MIN_SYMBOLS=25

# ---- News ---------------------------------------------------------------
NEWS_PROVIDER=alpaca       # alpaca (no key) | finnhub | newsapi
NEWSAPI_API_KEY=
FINNHUB_API_KEY=
NEWS_LOOKBACK_HOURS=12
NEWS_MAX_ARTICLES_PER_SYMBOL=15

# ---- Sentiment ---------------------------------------------------------------
SENTIMENT_PROVIDER=lexicon # lexicon (no key) | claude | openai
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
SENTIMENT_TEMPERATURE=0.0

# ---- Strategy: buy / sell rules -------------------------------------------
STRATEGY_BUY_THRESHOLD=8.0
STRATEGY_SELL_THRESHOLD=-5.0
STRATEGY_MIN_HEADLINES=5
STRATEGY_SELL_MIN_HEADLINES=3
STRATEGY_MAX_INTRADAY_RUNUP_PCT=8.0

# --- Confirmation filters (new) ---
STRATEGY_REQUIRE_PRICE_ABOVE_SMA=true
STRATEGY_SMA_PERIOD=20
STRATEGY_MIN_VOLUME_RATIO=1.5
STRATEGY_VOLUME_LOOKBACK_DAYS=20

# --- Market filters ---
STRATEGY_MARKET_FILTER_SYMBOL=SPY
STRATEGY_MARKET_FILTER_MAX_DROP_PCT=2.0        # pause buys if SPY down > X% today (0 disables)
STRATEGY_MARKET_REGIME_FILTER_ENABLED=true     # pause buys if SPY below its own SMA
STRATEGY_MARKET_REGIME_MA_PERIOD=50            # ...the 50-day SMA, specifically

# ---- Risk ---------------------------------------------------------------
RISK_DRY_RUN=true                # start here; flip to false only after watching it run
RISK_MAX_POSITION_PCT=5.0
RISK_MAX_OPEN_POSITIONS=10
RISK_MAX_TOTAL_EXPOSURE_PCT=50.0
RISK_MAX_NEW_POSITIONS_PER_CYCLE=3
RISK_MAX_POSITIONS_PER_SECTOR=3
RISK_REENTRY_COOLDOWN_HOURS=24
RISK_STOP_LOSS_PCT=10.0
RISK_TAKE_PROFIT_PCT=20.0
RISK_MAX_ORDER_NOTIONAL=0        # 0 = disabled
RISK_DAILY_LOSS_LIMIT_PCT=4.0

# ---- Schedule ---------------------------------------------------------------
SCHEDULE_RUN_MINUTES=0,30
SCHEDULE_MARKET_TIMEZONE=America/New_York

# ---- Logging & data persistence --------------------------------------------
# IMPORTANT on Railway: the filesystem is EPHEMERAL unless you attach a
# Volume. Without one, state.json / trades.csv / closed_trades.csv reset on
# every redeploy — cooldowns and the performance report's trade history
# disappear. Attach a Volume (Railway dashboard -> your service -> Volumes)
# and point these paths at its mount, e.g. /data/...  See DEPLOYMENT.md.
TRADE_LOG_PATH=logs/trades.csv
CLOSED_TRADES_PATH=logs/closed_trades.csv
DAILY_SUMMARY_PATH=logs/daily_summary.log
REPORT_DIR=logs/reports
RUN_LOG_PATH=logs/bot.log
STATE_PATH=logs/state.json

LOG_LEVEL=INFO
LOG_FORMAT=text            # text (human-readable) | json (structured, recommended on Railway)

# ---- Retry policy (applies to every external API call) ---------------------
RETRY_MAX_ATTEMPTS=4
RETRY_BASE_DELAY_SECONDS=1.0

# ---- Railway "Web Service" compatibility (optional) ------------------------
# If you deploy this as a Railway Worker (recommended), PORT is unset and
# this is irrelevant. If you deploy as a Web Service, Railway sets PORT for
# you automatically — you don't need to set it yourself.
# PORT=8080
