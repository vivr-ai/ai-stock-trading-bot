# Points at the SAME Postgres database the bot writes to (Railway auto-injects
# DATABASE_URL to every service in the project once you add the Postgres plugin).
DATABASE_URL=postgres://user:password@host:5432/railway

# Shared password for the dashboard login (Phase 1: single password gate).
DASHBOARD_PASSWORD=change-me

# NextAuth session encryption secret. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-too

# Set to the dashboard's public Railway URL once deployed, e.g.
# https://your-dashboard.up.railway.app - required by NextAuth in production.
NEXTAUTH_URL=http://localhost:3000
